// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Stan konta Emerald (Portfel)
model Wallet {
  id        String   @id @default(uuid())
  balance   Decimal  @default(4250.00) @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
}

// 2. Baza Produktów (Twój asortyment)
model Product {
  id        String   @id @default(uuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  imageUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacja: Jeden produkt może mieć wiele kampanii (lub jedną aktywną)
  campaigns Campaign[]
}

// 3. Baza Kampanii
model Campaign {
  id        String   @id @default(uuid())
  name      String
  bidAmount Decimal  @db.Decimal(10, 2)
  fund      Decimal  @db.Decimal(10, 2)
  status    Boolean  @default(true)
  town      String? // Opcjonalne, zgodnie z Twoim formularzem
  radius    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacja z Produktem
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Relacja Wiele-do-Wielu ze Słowami Kluczowymi (Prisma automatycznie stworzy tabelę łączącą)
  keywords Keyword[]
}

// 4. Słownik Słów Kluczowych (dla pre-populated typeahead)
model Keyword {
  id        String     @id @default(uuid())
  name      String     @unique // "elektronika", "sport" itp.
  campaigns Campaign[]
}

// 5. Opcjonalnie: Słownik Miast (jeśli chcesz trzymać listę miast w bazie, a nie tylko w kodzie)
model Town {
  id   String @id @default(uuid())
  name String @unique // "Warszawa", "Kraków" itp.
}
